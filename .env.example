# Caminho do binário claude. Default: $HOME/.local/bin/claude
CLAUDE_BIN=

# Ativa o skip de chamadas quando já existe sessão ativa recente. Default: true
ENABLE_SESSION_SKIP=

# Janela (minutos) considerada "sessão ativa" desde a última chamada. Default: 300
SESSION_WINDOW_MINUTES=

# Arquivo usado como sinal de atividade recente do usuário no Claude Code. Default: $HOME/.claude/history.jsonl
CLAUDE_ACTIVITY_FILE=
